# Copy to `.env` for local dev / `npm run build`. Never commit `.env`.
#
# --- Supabase (rebrand project) ---
# Dashboard: https://supabase.com/dashboard/project/essjyrhhaiywotvgjkcg
VITE_SUPABASE_PROJECT_ID=essjyrhhaiywotvgjkcg
VITE_SUPABASE_URL=https://essjyrhhaiywotvgjkcg.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
#
# --- Client (Vite) ---
# Set true when android/app/google-services.json is present (Codemagic / local release builds).
VITE_ANDROID_PUSH_REGISTER=
# --- OneSignal (native push + in-app messages) ---
VITE_ONESIGNAL_APP_ID=
#
# --- Meta ads -- Events Manager -> Data sources -> Pixel (web) ---
VITE_META_PIXEL_ID=
# Meta App Events (native) -- Meta for Developers -> Settings -> Basic
VITE_META_FACEBOOK_APP_ID=
# Injected into native builds via Codemagic: META_FACEBOOK_CLIENT_TOKEN (not VITE_)
# Meta Conversions API (optional server-side web events -- supabase/functions/tiktok-events legacy route):
# META_PIXEL_ID=
# META_CONVERSIONS_API_ACCESS_TOKEN=
#
# --- AppsFlyer (native install / session / deep link attribution) ---
VITE_APPSFLYER_DEV_KEY=
# iOS native app numeric id (when available)
VITE_APPSFLYER_IOS_APP_ID=
#
# --- Supabase Edge Function secrets (Dashboard -> Project Settings -> Edge Functions -> Secrets) ---
# Native + web RC sync (unchanged mobile paths):
# REVENUECAT_SECRET_KEY=sk_...
# REVENUECAT_WEBHOOK_AUTHORIZATION=...
#
# TikTok Events API (Pixel 062026 -- funnel events + Purchase from revenuecat-webhook):
# Events Manager -> Pixel 062026 -> Settings -> Generate access token
# TIKTOK_EVENTS_API_ACCESS_TOKEN=
# Optional -- Events Manager -> Test server-side events -> copy code (e.g. TEST27251)
# TIKTOK_TEST_EVENT_CODE=
# Remove TIKTOK_TEST_EVENT_CODE after events show in the test panel.
# Deploy: supabase functions deploy tiktok-events revenuecat-webhook
# Migration: 20260601120000_web_onboarding_sessions_ttclid_user_id.sql
# REVENUECAT_STRIPE_APP_PUBLIC_API_KEY=
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Brevo paywall welcome (cron: process-user-plan-brevo-welcome; not used by app build):
# BREVO_API_KEY=xkeysib-...
# BREVO_WELCOME_TEMPLATE_ID=2
# BREVO_WELCOME_TEMPLATE_ID_ES_419=
# BREVO_WELCOME_TEMPLATE_ID_PT_BR=
# BREVO_WELCOME_ENABLED=true   (default on when unset; set false to disable)
# CRON_SECRET=
# BREVO_PAYWALL_LIST_ID=7   (default 7 in code; optional override)
# Deploy: supabase functions deploy process-user-plan-brevo-welcome
# Migration: 20260604220000_user_plans_brevo_welcome_queue.sql
#
# Brevo cancellation list (cron: process-user-plan-brevo-cancellation; not used by app build):
# BREVO_CANCELLATION_LIST_ID=8   (default 8 in code; optional override)
# BREVO_CANCELLATION_ENABLED=true   (default on when unset; set false to disable)
# BREVO_CANCELLATION_TEMPLATE_ID=   (optional -- omit until cancellation email template exists)
# BREVO_CANCELLATION_TEMPLATE_ID_ES_419=
# BREVO_CANCELLATION_TEMPLATE_ID_PT_BR=
# Deploy: supabase functions deploy process-user-plan-brevo-cancellation
# Migration: 20260604240000_user_plans_brevo_cancellation_queue.sql
#
# Routine push (cron: send-routine-push-notifications; not used by app build):
# Sends at each user's chosen HH:mm times in user_preferences.timezone (IANA).
# ONESIGNAL_APP_ID=          (same App ID as VITE_ONESIGNAL_APP_ID)
# ONESIGNAL_REST_API_KEY=    (OneSignal Dashboard -> Settings -> Keys & IDs -> REST API Key)
# ROUTINE_PUSH_WORKER_ENABLED=true   (default on when unset; set false to disable)
# Launch URL: omitted by default (tap foregrounds app; optional on older iOS).
# Optional: ROUTINE_PUSH_LAUNCH_URL=capacitor://localhost/dashboard
# Disable explicitly: ROUTINE_PUSH_LAUNCH_URL=none
# Sound: celestial_bloom (ios/App/App/celestial_bloom.wav + android res/raw/celestial_bloom.wav)
# Deploy: supabase functions deploy send-routine-push-notifications
# Migrations: 20260607150000_profiles_timezone_mirror.sql, 20260607160000_routine_push_delivery_log.sql
# pg_cron: every 5 minutes -- see SQL comment in 20260607160000_routine_push_delivery_log.sql
#
# Help request reply push (server-only cron worker; no app build required):
# pg_cron calls process-help-reply-push-queue every minute; polls support inbox_messages.
# Backup: admin inbox invokes send-help-request-reply-push after admin reply.
# Uses same ONESIGNAL_* secrets + celestial_bloom sound.
# HELP_REPLY_PUSH_WORKER_ENABLED=true   (default on when unset; set false to disable)
# Launch URL: omitted by default (tap foregrounds app -- fixes older iOS unlocked /login flash).
# Optional: HELP_REPLY_PUSH_LAUNCH_URL=capacitor://localhost/dashboard
# Disable explicitly: HELP_REPLY_PUSH_LAUNCH_URL=none
# Deploy: supabase functions deploy process-help-reply-push-queue send-help-request-reply-push
# pg_cron: every minute -- POST process-help-reply-push-queue with CRON_SECRET (same as routine push)
#
# Board reminders (cron: process-board-reminders; not used by app build):
# Sends due board_reminders via send-email-notification and send-sms-notification.
# Action text reminders use Brevo transactional SMS (purpose=board-reminder).
# Phone verification codes also use Brevo transactional SMS.
# BREVO_API_KEY=xkeysib-...
# BREVO_REMINDER_FROM_EMAIL=reminders@yourdomain.com
# BREVO_REMINDER_FROM_NAME=Palette Plot Reminders
# BREVO_SMS_SENDER=Palette   (max 11 chars; required for Brevo SMS)
# Daily cap: 5 SMS per user per local day (user_preferences.timezone; enforced in process-board-reminders).
# Email and iCal export remain unlimited.
# OPENAI_API_KEY required for extract-board-insights (client-invoked).
# Deploy: supabase functions deploy extract-board-insights process-board-reminders
# Migrations: 20260702140000_board_system.sql, 20260702150000_board_reminders_cron.sql
# pg_cron: every 5 minutes -- see SQL comment in 20260702150000_board_reminders_cron.sql
#
# --- Tool site lock (tool.paletteplotting.com; tool.paletteplot.com alias still works) ---
# Auto-enabled on hostname tool.paletteplotting.com. Set true to force lock locally:
# VITE_SITE_LOCK_ENABLED=true
#
# Edge Function secret (Supabase Dashboard -> Edge Functions -> Secrets):
# SITE_ACCESS_PASSWORD=your-private-preview-password
#
# Newsletter waitlist (subscribe-palette-letter edge function):
# BREVO_PALETTE_LETTER_LIST_ID=   (optional Brevo list for The Palette Letter)
# Deploy: supabase functions deploy verify-site-access subscribe-palette-letter
#
# Digital palette plotting Guide (palette-plotting-guide page):
# DIGITAL_SESSION_SECRET=          (optional — HMAC for guide reader tokens; falls back to service role key)
# DIGITAL_SITE_ORIGIN=https://paletteplotting.com
# P_STRIPE_PRICE_GUIDE=price_...   (optional Stripe Price; else P_STRIPE_GUIDE_AMOUNT cents, default 1499)
# Deploy: supabase functions deploy digital-unlock digital-session palette-plotting-guide-reader create-guide-checkout
