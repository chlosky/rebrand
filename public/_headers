# index.html must not be cached long — it references hashed /assets/*.js chunks.
# A stale index + fresh assets (or vice versa) causes lazy routes to fetch HTML
# instead of JS (MIME type text/html) and Embody/other tools white-screen.
# SPA routes (/dashboard, …) also serve index.html — they must
# match this no-cache rule, not only / and /index.html.
/*
  Cache-Control: no-cache, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*.js
  Content-Type: application/javascript; charset=utf-8

/assets/*.css
  Content-Type: text/css; charset=utf-8

# Serve sitemap.xml with correct content type
/sitemap.xml
  Content-Type: application/xml; charset=utf-8

# Serve MediaPipe files with correct MIME types and caching
/mediapipe/*
  Cache-Control: public, max-age=31536000, immutable

/mediapipe/*.js
  Content-Type: application/javascript

/mediapipe/*.wasm
  Content-Type: application/wasm

/mediapipe/*.tflite
  Content-Type: application/octet-stream

/mediapipe/*.binarypb
  Content-Type: application/octet-stream

/email-video.mp4
  Content-Type: video/mp4
  Cache-Control: public, max-age=31536000, immutable
